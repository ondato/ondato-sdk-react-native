{
  "name": "ondato-sdk-react-native",
  "version": "3.5.1",
  "description": "Ondato React Native SDK: A drop-in component library for capturing identity documents and facial biometrics. Features advanced image quality detection and direct upload to simplify identity verification integration.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "ondato-sdk-react-native-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "app.plugin.js",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace ondato-sdk-react-native-example",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build && yarn expo:prepare",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta",
    "release:beta:patch": "release-it --preRelease=beta --increment=patch",
    "release:beta:minor": "release-it --preRelease=beta --increment=minor",
    "release:beta:major": "release-it --preRelease=beta --increment=major",
    "expo:build:plugin": "expo-module build plugin",
    "expo:clean:plugin": "expo-module clean plugin",
    "expo:test:plugin": "cd plugin && jest",
    "expo:prepare": "expo-module prepare"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ondato/ondato-sdk-react-native.git"
  },
  "author": "Ondato <info@ondato.com> (https://github.com/ondato)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ondato/ondato-sdk-react-native/issues"
  },
  "homepage": "https://github.com/ondato/ondato-sdk-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "fs-extra": "^11.3.2",
    "lodash": "^4.17.21",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "commitlint": "^21.0.2",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "expo": "^54.0.0",
    "expo-build-properties": "^1.0.8",
    "expo-module-scripts": "^5.0.7",
    "jest": "^29.7.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^20.2.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "expo": ">=53.0.0",
    "expo-build-properties": ">=1.0.8",
    "react": "*",
    "react-native": ">=0.77.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNOndatoSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.ondato"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "require",
        "react-native",
        "<%- project.sourceCondition -%>"
      ]
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/plugin/",
      "<rootDir>/lib/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commit": false,
      "tag": false,
      "push": false,
      "requireUpstream": false,
      "requireCleanWorkingDir": false
    },
    "npm": {
      "publish": false,
      "ignoreVersion": false
    },
    "github": {
      "release": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        },
        "infile": "CHANGELOG.md"
      }
    },
    "hooks": {
      "after:bump": "bash ../scripts/bump-versions.sh ${version}"
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.63.0"
  }
}
